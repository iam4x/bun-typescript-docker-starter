{
  "name": "bun-typescript-docker-starter",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "start": "bun run dist/index.js",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "bun test",
    "dev": "bun run --watch src/index.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  }
}

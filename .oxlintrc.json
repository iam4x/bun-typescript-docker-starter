{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "import"],
  "jsPlugins": [
    { "name": "import-js", "specifier": "eslint-plugin-import" },
    "./oxlint-eslint-compat-plugin.mjs"
  ],
  "env": {
    "browser": true,
    "node": true
  },
  "ignorePatterns": ["dist", "node_modules"],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "settings": {
    "import/resolver": {
      "typescript": true,
      "node": true
    }
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "ignoreRestSiblings": true
      }
    ],
    "import-js/order": [
      "error",
      {
        "newlines-between": "always"
      }
    ],
    "import-js/no-unresolved": [
      "error",
      {
        "ignore": ["bun:test"]
      }
    ],
    "eslint-compat/object-shorthand": "error",
    "typescript/no-empty-object-type": [
      "error",
      {
        "allowInterfaces": "always"
      }
    ]
  }
}
